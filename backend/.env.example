# ============================================
# GrowEasy CSV Importer — Backend Environment
# ============================================

# Server
PORT=3001
NODE_ENV=development

# CORS — Frontend URL (adjust for production)
CORS_ORIGIN=http://localhost:3000

# AI Provider — Google Gemini
GEMINI_API_KEY=AIzaSyA-3-5-pGyqmdSP3EcpNh7_WkVS-ix7JOo
# Batch Processing
BATCH_SIZE=20
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

MAX_FILE_SIZE_MB=10

# Firebase Admin SDK Configuration
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=

# Option 2: Inline Service Account values (fallback if file is not specified)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
